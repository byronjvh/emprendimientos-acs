									alt="pasteleria logo"
								/>
								<div>
									<p class="emprendimiento-autor-nombre">
										Juan Pablo Corella
									</p>
									<p
										class="emprendimiento-autor-departamento"
									>
										Depto. TI
									</p>
								</div>
							</div>
							<div class="emprendimiento-enlaces">
								<a href=""
									><i class="fa-brands fa-instagram"></i></a
								>
