---
import Emprendimiento from "./Emprendimiento.astro";
import { emprendimientos } from "../emprendimientos";
---

<div id="container">
	<div class="hero">
		<div class="hero-texto">
			<h1>Talento que <span class="titulo-destacado">Emprende</span></h1>
			<p class="intro">
				Descubre los emprendimientos de nuestros colaboradores, donde la
				innovación va más allá del trabajo diario.
			</p>
		</div>
		<a href="#emprendimientos" class="hero-button"
			>EXPLORAR EMPRENDIMIENTOS <i class="fa-solid fa-arrow-right-long"
			></i></a
		>
		<div class="scroll">
			<div class="mouse">
				<span class="mouse-wheel"></span>
			</div>
			<p>SCROLL</p>
		</div>
	</div>
	<main id="emprendimientos" class="emprendimientos">
		<h3 class="emprendimientos-titulo">TODOS LOS EMPRENDIMIENTOS</h3>
		<ul class="emprendimientos-lista">
			{
				emprendimientos?.map((el, i) => (
					<li>
						<Emprendimiento
							title={el.title}
							description={el.description}
							category={el.category}
							image={el.image}
							logo={el.logo}
							name={el.name}
							position={el.position}
							whatsapp={el.whatsapp}
							facebook={el.facebook}
							website={el.website}
							instagram={el.instagram}
							linkText={el.linkText}
						/>
					</li>
				))
			}
		</ul>
	</main>
	<footer class="footer">Corporación ACS</footer>
</div>

<style></style>
