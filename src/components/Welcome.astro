										class="emprendimiento-autor-departamento"
									>
										Asesora Call Center
									</p>
								</div>
							</div>
							<div class="emprendimiento-enlaces">
								<a
									target="_blank"
									rel="noopenner noreferer"
									href="https://wa.me/50683636171"
									><i class="fa-brands fa-whatsapp"></i><span
										style="font-size: 12px;"
									>
										8363-6171</span
									></a
								>
							</div>
						</footer>
					</div>
				</article>
			</li>
			<li>
				<article class="emprendimiento">
					<div class="emprendimiento-imagen">
						<img
							class=""
							src="/lista/delicias-mi-tita/Delicias_mi_tita.jpeg"
							alt="delicias mi tita"
						/>
					</div>
					<div class="emprendimiento-contenido">
						<div class="emprendimiento-texto">
							<span class="tag">🍰 Gastronomía</span>
